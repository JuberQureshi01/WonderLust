<% layout("./layout/boilerplate.ejs") %>
<link rel="stylesheet" href="/public/style.css">
  <body>
    <style>
      
    </style>
    <div id="filters">
      <div class="filter" >
         <a href="http://localhost:8080/listings/category/Trending">
          <i class="fa-solid fa-fire"></i>
          <p>Trending </p>
        </a>
      </div>

      <div class="filter">
        <a href="http://localhost:8080/listings/category/Rooms"><i class="fa-solid fa-bed"></i>
          <p>Rooms</p>
        </a>
      </div>

      <div class="filter">
        <a href="http://localhost:8080/listings/category/Iconiccities"><i class="fa-solid fa-mountain-city"></i>
          <p>Iconic Cities</p>
        </a>
      </div>

      <div class="filter">
        <a href="http://localhost:8080/listings/category/Mountains"><i class="fa-solid fa-mountain"></i>
          <p>Mountains</p>
        </a>
      </div>

      <div class="filter">
        <a href="http://localhost:8080/listings/category/Amazingpools"><i class="fa-solid fa-person-swimming"></i>
          <p>Amazing Pools </p>
        </a>
      </div>

      <div class="filter">
        <a href="http://localhost:8080/listings/category/Camping"><i class="fa-solid fa-campground"></i>
          <p>Camping</p>
        </a>
      </div>

      <div class="filter">
        <a href="http://localhost:8080/listings/category/Castles"> <i class="fa-brands fa-fort-awesome"></i>
          <p>Castles</p>
        </a>
      </div>
      <div class="filter">
        <a href="http://localhost:8080/listings/category/Farming"><i class="fa-solid fa-cow"></i>
          <p>Farming</p>
        </a>
      </div>
      <div class="filter">
        <a href="http://localhost:8080/listings/category/Arctic"><i class="fa-regular fa-snowflake"></i>
          <p>Arctic</p>
        </a>
      </div>
      <div class="filter">
        <a href="http://localhost:8080/listings/category/Domes"><i class="fa-solid fa-igloo"></i>
          <p>Domes</p>
        </a>
      </div>
      <div class="tax-toggle ">
        <div class="form-check-reverse form-switch border-dark">
          <input class="form-check-input" type="checkbox" role="switch" id="flexSwitchCheckDefault">
          <label class="form-check-label" for="flexSwitchCheckDefault">Display total after taxes</label>
        </div>
      </div>
    </div>

    <div class="row row-cols-lg-3 row-cols-md-2 row-cols-sm-1 mt-3  ">

      <% for (let category of categoryList) { %>

        <a href="/listings/<%= category._id %>" class="listing-link">
          <div class="card  listing-card">
            <img src="<%= category.image.url %>" class="card-img-top " alt="listingimage" style="height: 20rem;">
            <div class="card-img-overlay"></div>
            <div class="card-body">
              <p class="card-text">
                <b>
                  <%=category.title %>
                </b>
                <br>
                &#8377 <%=category.price.toLocaleString("en-IN")%> /night
                  <i class="tax-info">&nbsp; &nbsp; +18% GST</i>
              </p>
            </div>
          </div>
        </a>
        <% } %>

    </div>
    <% if(categoryList.length==0) {%>
      <div class="notfound">No Hotels available for this category </div>
      <% } %>

      <script src="/public/script.js">
    </script>
  </body>